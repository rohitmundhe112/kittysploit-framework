{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kittysploit.local/schemas/v1/kittyforge_graph.json",
  "title": "KittyForge operational graph",
  "type": "object",
  "required": ["schema_version", "nodes", "edges"],
  "properties": {
    "schema_version": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "label"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "label": { "type": "string" },
          "meta": { "type": "object" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "relation"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "relation": { "type": "string" }
        }
      }
    },
    "summary": { "type": "object" }
  }
}
