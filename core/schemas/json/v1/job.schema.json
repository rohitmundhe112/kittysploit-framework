{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kittysploit.dev/json/v1/job.schema.json",
  "title": "KittySploit Job",
  "description": "A background or asynchronous execution job with module, target, timing, output, and result references.",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version"
    },
    "id": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/id"
        },
        {
          "type": "integer",
          "minimum": 0
        }
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "cancelled",
        "killed",
        "timeout",
        "unknown"
      ]
    },
    "workspace": {
      "type": [
        "string",
        "null"
      ]
    },
    "target": {
      "oneOf": [
        {
          "$ref": "target.schema.json"
        },
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "module": {
      "$ref": "common.schema.json#/$defs/module_ref"
    },
    "pid": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "started_at": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "completed_at": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "killed_at": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "updated_at": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "progress": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "percent": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "current_step": {
          "type": [
            "string",
            "null"
          ]
        },
        "total_steps": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": [
        "string",
        "null"
      ]
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    },
    "result": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "success": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "finding": {
          "oneOf": [
            {
              "$ref": "finding.schema.json"
            },
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "evidence.schema.json"
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "default": []
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "$ref": "common.schema.json#/$defs/nullable_id"
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "$ref": "common.schema.json#/$defs/tags"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    }
  },
  "required": [
    "id",
    "name",
    "status"
  ],
  "additionalProperties": false
}
