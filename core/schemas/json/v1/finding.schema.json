{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kittysploit.dev/json/v1/finding.schema.json",
  "title": "KittySploit Finding",
  "description": "A security finding with normalized severity, status, targets, evidence, remediation, and retest state.",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/id"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "category": {
      "type": [
        "string",
        "null"
      ]
    },
    "severity": {
      "$ref": "common.schema.json#/$defs/severity"
    },
    "status": {
      "type": "string",
      "enum": [
        "affected",
        "not_affected",
        "fixed",
        "under_investigation",
        "open",
        "triaged",
        "accepted_risk",
        "false_positive",
        "informational",
        "closed",
        "unknown"
      ]
    },
    "cve": {
      "$ref": "common.schema.json#/$defs/cve"
    },
    "cwe": {
      "$ref": "common.schema.json#/$defs/cwe"
    },
    "cvss_score": {
      "$ref": "common.schema.json#/$defs/cvss_score"
    },
    "affected_targets": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "target.schema.json"
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "default": []
    },
    "target": {
      "oneOf": [
        {
          "$ref": "target.schema.json"
        },
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "evidence.schema.json"
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "default": []
    },
    "remediation": {
      "type": [
        "string",
        "null"
      ]
    },
    "module": {
      "$ref": "common.schema.json#/$defs/module_ref"
    },
    "job_id": {
      "$ref": "common.schema.json#/$defs/nullable_id"
    },
    "session_id": {
      "$ref": "common.schema.json#/$defs/nullable_id"
    },
    "references": {
      "$ref": "common.schema.json#/$defs/references"
    },
    "confidence": {
      "$ref": "common.schema.json#/$defs/confidence"
    },
    "exploitability": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "confirmed",
        "unknown",
        null
      ]
    },
    "first_seen": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "last_seen": {
      "oneOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "retest": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "last_tested_at": {
          "oneOf": [
            {
              "$ref": "common.schema.json#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "last_result": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "pass",
            "fail",
            "skipped",
            "pending",
            "passed",
            "failed",
            "inconclusive",
            "not_run",
            null
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "required"
      ],
      "additionalProperties": false
    },
    "tags": {
      "$ref": "common.schema.json#/$defs/tags"
    },
    "metadata": {
      "$ref": "common.schema.json#/$defs/metadata"
    }
  },
  "required": [
    "id",
    "title",
    "severity",
    "status"
  ],
  "additionalProperties": false
}
